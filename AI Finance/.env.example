# ──────────────────────────────────────────────────────────────────────────────
# Finova – Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control — it is already in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
# Connection pooler URL (used by Prisma at runtime via PgBouncer)
DATABASE_URL=""
# Direct (non-pooled) connection URL (used by Prisma Migrate)
DIRECT_URL=""

# ── Clerk Authentication ───────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Upstash Redis (Rate Limiting) ─────────────────────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API tab
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Inngest (Background Jobs) ─────────────────────────────────────────────────
# On Vercel: these are automatically injected by the Inngest integration.
# For local dev: get from https://app.inngest.com → Your App → Signing keys
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ── Resend (Transactional Email) ──────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=""

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ── Market Data (Portfolio Manager) ───────────────────────────────────────────
# Get from: https://twelvedata.com (800 free requests per day)
TWELVE_DATA_API_KEY=""

